# ==============================
# Backend API via Kong (HTTPS)
# ==============================
REACT_APP_BACKEND_URL=https://192.168.5.162:9443/api

# ==============================
# Ambiente
# ==============================
NODE_ENV=production
ENABLE_HEALTH_CHECK=true

# ==============================
# Configurações de segurança
# ==============================
REACT_APP_USE_HTTPS=true

# ==============================
# Integração com SharePoint (via backend)
# ==============================
REACT_APP_SHAREPOINT_ENABLED=true
