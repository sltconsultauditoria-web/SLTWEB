# ==============================
# BASE URL (CRÍTICO - GitHub Pages)
# ==============================
PUBLIC_URL=/SLTWEB

# ==============================
# API BACKEND (PRODUÇÃO)
# ==============================

# ==============================
# COMPATIBILIDADE LEGADA (se já usado no código)
# ==============================
REACT_APP_BACKEND_URL=https://192.168.5.162:9443/api

# ==============================
# AMBIENTE
# ==============================
NODE_ENV=production
REACT_APP_ENV=production

# ==============================
# SEGURANÇA / PROTOCOLO
# ==============================
REACT_APP_USE_HTTPS=true

# ==============================
# FEATURES
# ==============================
REACT_APP_SHAREPOINT_ENABLED=true
ENABLE_HEALTH_CHECK=true

# ==============================
# DEBUG (DESLIGADO EM PRODUÇÃO)
# ==============================
REACT_APP_DEBUG=false
REACT_APP_API_URL=http://localhost:3000/api
