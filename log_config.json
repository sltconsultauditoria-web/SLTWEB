{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "default": {
      "format": "%(levelname)s %(asctime)s | %(message)s",
      "datefmt": "%Y-%m-%d %H:%M:%S"
    }
  },
  "handlers": {
    "default": {
      "formatter": "default",
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout"
    },
    "file": {
      "formatter": "default",
      "class": "logging.FileHandler",
      "filename": "logs/server.log"
    }
  },
  "loggers": {
    "uvicorn": {
      "handlers": ["default", "file"],
      "level": "DEBUG",
      "propagate": false
    },
    "uvicorn.error": {
      "level": "DEBUG"
    },
    "uvicorn.access": {
      "handlers": ["default", "file"],
      "level": "DEBUG",
      "propagate": false
    }
  }
}