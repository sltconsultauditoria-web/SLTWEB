
# Variáveis de Ambiente para o Backend (FastAPI)

# Configurações Gerais da Aplicação
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Configurações do Banco de Dados MongoDB
MONGODB_URL=mongodb://127.0.0.1:27017
DB_NAME=consultslt_db
ENABLE_DB_SEED=false

# Configurações de Autenticação JWT
SECRET_KEY=consultslt-secret-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Configurações de Armazenamento Local
LOCAL_STORAGE_PATH=/tmp/uploads

# Configurações de CORS (Cross-Origin Resource Sharing)
# Permite que o frontend (e outras origens) se comuniquem com o backend
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.5.162:3000,http://localhost:8000
