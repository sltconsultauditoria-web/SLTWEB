# ================================
# Ambiente
# ================================
APP_ENV=development
DEBUG=true

# ================================
# Servidor Backend
# ================================
HOST=0.0.0.0
PORT=8000

# ================================
# Banco de Dados MongoDB
# ================================
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=consultslt_db
DB_NAME=consultslt_db

# ================================
# Autenticação JWT
# ================================
JWT_SECRET=consultslt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ================================
# Configuração de inicialização
# ================================
ENABLE_DB_SEED=false
LOCAL_STORAGE_PATH=C:/Users/admin-local/ServerApp/uploads

# ================================
# CORS - Origens permitidas
# ================================
CORS_ORIGINS=https://192.168.5.162:3000,https://192.168.5.162:9443

# ================================
# Integração com SharePoint Online
# ================================
SHAREPOINT_SITE_URL=https://sltconsult.sharepoint.com/sites/RecibosFiscais
SHAREPOINT_LIBRARY_NAME=Recibos 2024
SHAREPOINT_FOLDER_PATH=/Recibos por Empresa

# Credenciais do Azure AD (Entra ID)
SHAREPOINT_TENANT_ID=<seu-tenant-id>
SHAREPOINT_CLIENT_ID=<seu-client-id>
SHAREPOINT_CLIENT_SECRET=<seu-client-secret>
